<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.5.0/rti_recording_service.xsd">

  <!--
    Variable-driven Recording Service template.
    Override values with -DREC_*=... at launch.

    Example:
      rtirecordingservice \
        -cfgFile "dds/qos/recording_service.xml;dds/qos/DDS_QOS_PROFILES.xml" \
        -cfgName template \
        -DREC_DOMAIN_ID=42 \
        -DREC_STORAGE_FORMAT=XCDR_AUTO
  -->
  <configuration_variables>
    <value>
      <element><name>REC_DOMAIN_ID</name><value>0</value></element>
      <element><name>REC_ADMIN_DOMAIN_ID</name><value>0</value></element>
      <element><name>REC_MON_DOMAIN_ID</name><value>0</value></element>

      <element><name>REC_SESSION_NAME</name><value>recording_session</value></element>
      <element><name>REC_LOG_DIR</name><value>services/rs_gui/log_data</value></element>
      <element><name>REC_EXEC_DIR_EXPR</name><value>recording_%ts%</value></element>
      <element><name>REC_FILENAME_EXPR</name><value>data_%auto:0-9%.db</value></element>
      <element><name>REC_STORAGE_FORMAT</name><value>XCDR_AUTO</value></element>

      <element><name>REC_TOPIC_ALLOW</name><value>*</value></element>
      <element><name>REC_TOPIC_DENY</name><value>rti/*</value></element>

      <element><name>REC_DP_QOS</name><value>DPLibrary::DefaultParticipant</value></element>
      <element><name>REC_SUB_QOS</name><value>BuiltinQosLib::Generic.Common</value></element>
      <element><name>REC_DR_QOS</name><value>BuiltinQosLib::Generic.Common</value></element>

      <element><name>REC_STATUS_PERIOD_SEC</name><value>0</value></element>
      <element><name>REC_STATUS_PERIOD_NSEC</name><value>500000000</value></element>
      <element><name>REC_STATS_PERIOD_NSEC</name><value>500000000</value></element>

      <element><name>REC_ROLLOVER_ENABLED</name><value>false</value></element>
      <element><name>REC_ROLLOVER_MB</name><value>1024</value></element>
    </value>
  </configuration_variables>

  <!-- Single launch template; behavior is controlled by REC_* variables -->
  <recording_service name="template">
    <administration>
      <domain_id>$(REC_ADMIN_DOMAIN_ID)</domain_id>
      <datareader_qos base_name="ServiceAdministrationProfiles::ServiceAdminReplierProfile"/>
      <datawriter_qos base_name="ServiceAdministrationProfiles::ServiceAdminReplierProfile"/>
    </administration>

    <monitoring>
      <domain_id>$(REC_MON_DOMAIN_ID)</domain_id>
      <status_publication_period>
        <sec>$(REC_STATUS_PERIOD_SEC)</sec>
        <nanosec>$(REC_STATUS_PERIOD_NSEC)</nanosec>
      </status_publication_period>
      <statistics_sampling_period>
        <sec>0</sec>
        <nanosec>$(REC_STATS_PERIOD_NSEC)</nanosec>
      </statistics_sampling_period>
    </monitoring>

    <storage>
      <sqlite>
        <storage_format>$(REC_STORAGE_FORMAT)</storage_format>
        <fileset>
          <workspace_dir>$(REC_LOG_DIR)</workspace_dir>
          <execution_dir_expression>$(REC_EXEC_DIR_EXPR)</execution_dir_expression>
          <filename_expression>$(REC_FILENAME_EXPR)</filename_expression>
          <rollover>
            <enabled>$(REC_ROLLOVER_ENABLED)</enabled>
            <file_size_limit unit="MEGABYTES">$(REC_ROLLOVER_MB)</file_size_limit>
          </rollover>
        </fileset>
      </sqlite>
    </storage>

    <domain_participant name="RecordingServiceParticipant">
      <domain_id>$(REC_DOMAIN_ID)</domain_id>
      <domain_participant_qos base_name="$(REC_DP_QOS)"/>
    </domain_participant>

    <session name="$(REC_SESSION_NAME)">
      <subscriber_qos base_name="$(REC_SUB_QOS)"/>
      <topic_group name="RecordSelected" participant_ref="RecordingServiceParticipant">
        <allow_topic_name_filter>$(REC_TOPIC_ALLOW)</allow_topic_name_filter>
        <deny_topic_name_filter>$(REC_TOPIC_DENY)</deny_topic_name_filter>
        <datareader_qos base_name="$(REC_DR_QOS)"/>
      </topic_group>
    </session>
  </recording_service>
</dds>
