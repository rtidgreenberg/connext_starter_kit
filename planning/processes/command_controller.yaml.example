# planning/processes/command_controller.yaml
# ============================================================================
# PROCESS DESIGN — Generated by /rti_dev Phase 3 (Process Design)
# ============================================================================
#
# Second example process demonstrating:
#   - Type REUSE (references same gps_types.idl as gps_tracker)
#   - Command pattern option 2 (multi-source with EXCLUSIVE ownership)
#   - Failover STANDBY role (counterpart to gps_tracker's PRIMARY)
#   - Read-only process (no custom outputs — only system pattern outputs)
#
# Project config: planning/project.yaml (Wrapper Class, Modern C++)
# System config:  planning/system_config.yaml (v1, Failover + Health Monitoring)
# Last modified:  2026-03-17T15:00:00Z
# ============================================================================

process:
  name: command_controller
  description: >
    Issues commands to other processes (gps_tracker, etc.) with priority
    arbitration. Multiple command sources can exist — highest ownership
    strength wins via EXCLUSIVE ownership QoS. Participates in failover
    as STANDBY node.

  domain_id: null                    # Inherit from system_config (domain 0)
  transports: [SHMEM, UDP]

  system_config_version: 1

  system_patterns:
    - pattern: failover
      role: standby                  # STANDBY — monitors primary's heartbeat,
                                     # takes over on deadline miss

    - pattern: health_monitoring
      role: publisher                # Publishes its own health data

# ============================================================================
# IDL FILES
# ============================================================================
#
# NOTE: gps_types.idl is REUSED from gps_tracker's design — no new IDL written.
# The Command type already exists in this file. During implementation, rtiddsgen
# will process it and generate type support for this process too.
# ============================================================================

idl_files:
  - dds/datamodel/idl/gps_types.idl
    # REUSED — Contains: CommandAction (enum), Command (struct), Position (struct)
    # Originally created by gps_tracker design. No duplication.

  - dds/datamodel/idl/system_patterns.idl
    # Contains: ProcessRole, HeartbeatStatus, ProcessState, HealthStatus

# ============================================================================
# INPUTS
# ============================================================================

inputs:

  # No custom inputs — this process is a command ISSUER, not a receiver.

  # ── System Pattern I/O (auto-generated by failover.hot_standby) ──────────

  - name: heartbeat_input
    topic: HeartbeatTopic
    type: system_patterns::HeartbeatStatus
    pattern: status
    pattern_option: 3
    qos_profile: "SystemPatternsLibrary::HeartbeatQoS"
    callbacks:
      - data_available
      - liveliness_changed
      - requested_deadline_missed
    auto_generated_by: failover.hot_standby

# ============================================================================
# OUTPUTS
# ============================================================================

outputs:

  # ── Custom I/O (user-defined) ────────────────────────────────────────────

  - name: command_output
    topic: CommandTopic
    type: gps_types::Command         # REUSED type — same as gps_tracker's input type
    pattern: command
    pattern_option: 2                # Multi-source with EXCLUSIVE ownership
                                     #   command.1 = Single-source (SHARED)
                                     #   command.2 = Multi-source (EXCLUSIVE + strength)
    qos_profile: "DataPatternsLibrary::CommandStrength20QoS"
                                     # Strength 20 — higher than default (10),
                                     # lower than override (30). Allows priority layering.
    callbacks:
      - publication_matched

  # ── System Pattern I/O (auto-generated by failover.hot_standby) ──────────

  - name: heartbeat_output
    topic: HeartbeatTopic
    type: system_patterns::HeartbeatStatus
    pattern: status
    pattern_option: 3
    qos_profile: "SystemPatternsLibrary::HeartbeatQoS"
    rate_hz: 1
    callbacks:
      - publication_matched
    auto_generated_by: failover.hot_standby

  # ── System Pattern I/O (auto-generated by health_monitoring.app_heartbeat)

  - name: health_output
    topic: HealthStatusTopic
    type: system_patterns::HealthStatus
    pattern: status
    pattern_option: 3
    qos_profile: "SystemPatternsLibrary::HealthMonitorQoS"
    rate_hz: 1
    callbacks:
      - publication_matched
    auto_generated_by: health_monitoring.app_heartbeat

# ============================================================================
# APPLICATION LOGIC
# ============================================================================

application_logic:
  - name: failover_monitor
    trigger: requested_deadline_missed on heartbeat_input
    action: >
      Promote self from STANDBY to PRIMARY. Begin issuing commands.
      Update heartbeat role field. Set EXCLUSIVE ownership strength to 100.
    auto_generated_by: failover.hot_standby

  - name: ownership_switch
    trigger: role change to PRIMARY
    action: >
      Set EXCLUSIVE ownership strength to 100 on all outputs.
    auto_generated_by: failover.hot_standby

  - name: command_issuer
    trigger: user-defined (periodic or event-driven)
    action: >
      Build Command message with appropriate action and device_id.
      Publish via command_output writer. Log command sent.

# ============================================================================
# TESTS
# ============================================================================

tests:
  unit:
    - name: test_command_publish
      verifies: command_output
      description: "Create writer with strength 20, publish Command, verify via reader"
      checks:
        - data_received
        - field_values_correct       # action is valid CommandType, device_id non-empty
        - ownership_strength_correct  # Verify EXCLUSIVE ownership with strength 20

    - name: test_heartbeat_publish
      verifies: heartbeat_output
      description: "Verify heartbeat published at 1Hz with STANDBY role"
      checks:
        - data_received
        - field_values_correct       # role = STANDBY, sequence_num increments
        - deadline_not_missed
      auto_generated_by: failover.hot_standby

    - name: test_health_status_publish
      verifies: health_output
      description: "Verify HealthStatus published at 1Hz with valid metrics"
      checks:
        - data_received
        - field_values_correct
      auto_generated_by: health_monitoring.app_heartbeat

  integration:
    - name: test_command_controller_e2e
      description: "Launch command_controller, verify it publishes commands"
      steps:
        - launch: command_controller
        - wait_for_discovery: 5s
        - verify:
            topic: CommandTopic
            received: true
            fields: { command_type: START }
        - stop: command_controller

    - name: test_command_priority_arbitration
      description: >
        Launch two command sources with different ownership strengths.
        Verify reader receives from higher-strength source only.
      steps:
        - launch: { process: command_controller, args: "--strength 20", name: "low_priority" }
        - launch: { process: command_controller, args: "--strength 30", name: "high_priority" }
        - wait_for_discovery: 5s
        - verify:
            topic: CommandTopic
            received: true
            from: high_priority       # Only highest strength should be received
        - kill: { process: high_priority }
        - wait: 3s
        - verify:
            topic: CommandTopic
            received: true
            from: low_priority        # Low priority takes over after high stops

    - name: test_failover_standby_takeover
      description: "Verify standby promotes to primary when primary heartbeat stops"
      steps:
        - launch: { process: command_controller, args: "--role STANDBY" }
        - wait: 2s
        - verify: { topic: HeartbeatTopic, field: role, value: STANDBY }
        # Simulate no primary heartbeat (deadline miss after 2s)
        - wait: 5s
        - verify: { topic: HeartbeatTopic, field: role, value: PRIMARY }
      auto_generated_by: failover.hot_standby

# ============================================================================
# DECISIONS
# ============================================================================

decisions:
  - id: plan.transports
    selected: [SHMEM, UDP]
    rationale: "Default — co-located + optional remote"
    timestamp: "2026-03-17T15:00:00Z"

  - id: plan.system_pattern_optin.failover
    selected: "standby"
    rationale: "Counterpart to gps_tracker's PRIMARY role"
    timestamp: "2026-03-17T15:00:05Z"

  - id: plan.system_pattern_optin.health_monitoring
    selected: "publisher"
    rationale: "All processes publish health data in this system"
    timestamp: "2026-03-17T15:00:06Z"

  - id: plan.type.CommandTopic
    selected: "gps_types::Command (existing)"
    rationale: "Reused from gps_tracker design — same type, no new IDL"
    timestamp: "2026-03-17T15:00:10Z"

  - id: plan.pattern.CommandTopic
    selected: "command.2"
    rationale: "Multi-source: multiple command controllers with priority arbitration"
    timestamp: "2026-03-17T15:00:15Z"

  - id: plan.tests
    selected: "accepted_with_addition"
    rationale: "Accepted auto-proposed tests + added test_command_priority_arbitration"
    timestamp: "2026-03-17T15:00:25Z"
