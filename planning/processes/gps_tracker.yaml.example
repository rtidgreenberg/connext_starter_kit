# planning/processes/gps_tracker.yaml
# ============================================================================
# PROCESS DESIGN — Generated by /rti_dev Phase 3 (Process Design)
# ============================================================================
#
# Complete specification of one DDS process. Planning writes it; implementation
# reads it. This is the single source of truth for the gps_tracker process.
#
# Project config: planning/project.yaml (Wrapper Class, Modern C++)
# System config:  planning/system_config.yaml (v1, Failover + Health Monitoring)
# Last modified:  2026-03-17T14:30:00Z
# ============================================================================

process:
  name: gps_tracker                  # Valid C identifier (no spaces, starts with letter)
  description: >
    Reads GPS coordinates from sensor, publishes position at 2Hz.
    Receives command messages to control tracking (start, stop, reset).
    Participates in system failover as PRIMARY node and publishes health data.

  domain_id: null                    # null = inherit from system_config (domain 0)
                                     # Set 0-232 to override for this process only.

  transports: [SHMEM, UDP]           # Per-process transport selection.
                                     # Options: SHMEM, UDP, TCP, or combinations.
                                     # Most common: [SHMEM, UDP] for co-located + remote.

  system_config_version: 1           # Must match system_config.yaml version.
                                     # Mismatch triggers sweep — agent offers
                                     # opt-in for new patterns or warns about changes.

  # ── System Pattern Opt-In ────────────────────────────────────────────────
  #
  # Only patterns from system_config.yaml are available here.
  # The APPROACH (e.g., hot_standby) is inherited from system config.
  # Only the ROLE is set per-process.
  # ──────────────────────────────────────────────────────────────────────────

  system_patterns:
    - pattern: failover
      role: primary                  # primary | standby
                                     # primary: publishes heartbeat, higher ownership strength
                                     # standby: monitors heartbeat, takes over on deadline miss

    - pattern: health_monitoring
      role: publisher                # publisher | monitor
                                     # publisher: emits HealthStatus at 1Hz
                                     # monitor: subscribes to and evaluates health data

# ============================================================================
# IDL FILES — Created during design (Phase 3, Step 2b)
# ============================================================================
#
# These .idl files are the source of truth for data modeling.
# The agent writes actual IDL to dds/datamodel/idl/ during design.
# During implementation, rtiddsgen generates code from these files.
# This list records which files this process depends on.
# ============================================================================

idl_files:
  - dds/datamodel/idl/gps_types.idl
    # Contains: CommandAction (enum), Command (struct), Position (struct)
    # Created during this process's design.

  - dds/datamodel/idl/system_patterns.idl
    # Contains: ProcessRole, HeartbeatStatus, ProcessState, HealthStatus
    # Auto-generated during Phase 2 (System Implementation).

# ============================================================================
# INPUTS — What this process subscribes to
# ============================================================================

inputs:

  # ── Custom I/O (user-defined) ────────────────────────────────────────────

  - name: command_input              # Internal name — used in code variable names
    topic: CommandTopic              # DDS topic name on the wire
    type: gps_types::Command         # Fully qualified IDL type (module::Type)
    pattern: command                 # event | status | command | parameter | large_data
    pattern_option: 1                # Option within pattern (see Data Patterns Reference)
                                     #   command.1 = Single-source (SHARED ownership)
                                     #   command.2 = Multi-source (EXCLUSIVE ownership)
    qos_profile: "DataPatternsLibrary::EventQoS"
    callbacks:
      - data_available               # Fires when new Command data arrives
      - liveliness_changed           # Fires when command source appears/disappears

  # ── System Pattern I/O (auto-generated by failover.hot_standby) ──────────

  - name: heartbeat_input
    topic: HeartbeatTopic
    type: system_patterns::HeartbeatStatus
    pattern: status
    pattern_option: 3                # Reliable Status with Deadline
    qos_profile: "SystemPatternsLibrary::HeartbeatQoS"
    callbacks:
      - data_available
      - liveliness_changed
      - requested_deadline_missed    # Key trigger: switches standby → primary
    auto_generated_by: failover.hot_standby
    # ⚠ Modifying auto-generated I/O may break failover behavior.

# ============================================================================
# OUTPUTS — What this process publishes
# ============================================================================

outputs:

  # ── Custom I/O (user-defined) ────────────────────────────────────────────

  - name: position_output
    topic: PositionTopic
    type: gps_types::Position
    pattern: status
    pattern_option: 1                # Standard Status — BEST_EFFORT, KEEP_LAST 1, Deadline
    qos_profile: "DataPatternsLibrary::StatusQoS"
    rate_hz: 2                       # Publish rate (for status/periodic patterns)
    callbacks:
      - publication_matched          # Fires when a reader discovers this writer

  # ── System Pattern I/O (auto-generated by failover.hot_standby) ──────────

  - name: heartbeat_output
    topic: HeartbeatTopic
    type: system_patterns::HeartbeatStatus
    pattern: status
    pattern_option: 3
    qos_profile: "SystemPatternsLibrary::HeartbeatQoS"
    rate_hz: 1
    callbacks:
      - publication_matched
    auto_generated_by: failover.hot_standby

  # ── System Pattern I/O (auto-generated by health_monitoring.app_heartbeat)

  - name: health_output
    topic: HealthStatusTopic
    type: system_patterns::HealthStatus
    pattern: status
    pattern_option: 3                # Reliable Status with Deadline
    qos_profile: "SystemPatternsLibrary::HealthMonitorQoS"
    rate_hz: 1
    callbacks:
      - publication_matched
    auto_generated_by: health_monitoring.app_heartbeat

# ============================================================================
# APPLICATION LOGIC — Auto-generated behavior markers
# ============================================================================
#
# These describe behavioral logic the code generator must implement.
# They are NOT I/O — they are instructions for builder.prompt.md.
# ============================================================================

application_logic:
  - name: failover_monitor
    trigger: requested_deadline_missed on heartbeat_input
    action: >
      Promote self from STANDBY to PRIMARY. Start publishing on all outputs.
      Update heartbeat role field. Set EXCLUSIVE ownership strength to 100.
    auto_generated_by: failover.hot_standby

  - name: ownership_switch
    trigger: role change to PRIMARY
    action: >
      Set EXCLUSIVE ownership strength to 100 on all outputs.
    auto_generated_by: failover.hot_standby

# ============================================================================
# TESTS — Auto-proposed from I/O definitions, reviewed by user
# ============================================================================

tests:
  unit:
    - name: test_position_publish
      verifies: position_output
      description: "Create writer, publish Position, verify via reader"
      checks:
        - data_received              # Reader gets at least one sample
        - field_values_correct       # latitude, longitude, altitude are non-zero
        - deadline_not_missed        # At 2Hz, deadline should not fire within 2s

    - name: test_command_receive
      verifies: command_input
      description: "Create writer, send Command, verify callback fires"
      checks:
        - data_received              # Command delivered to reader
        - liveliness_detected        # Writer liveliness is ALIVE

    - name: test_heartbeat_publish
      verifies: heartbeat_output
      description: "Verify heartbeat published at 1Hz with correct role"
      checks:
        - data_received
        - field_values_correct       # role = PRIMARY, sequence_num increments
        - deadline_not_missed
      auto_generated_by: failover.hot_standby

    - name: test_health_status_publish
      verifies: health_output
      description: "Verify HealthStatus published at 1Hz with valid metrics"
      checks:
        - data_received
        - field_values_correct       # cpu_percent >= 0, memory_mb > 0
      auto_generated_by: health_monitoring.app_heartbeat

  integration:
    - name: test_gps_tracker_e2e
      description: "Launch process, send Command, verify Position output"
      steps:
        - launch: gps_tracker
        - wait_for_discovery: 5s
        - publish:
            topic: CommandTopic
            data: { action: START, device_id: "test_device" }
        - wait: 3s
        - verify:
            topic: PositionTopic
            received: true
            min_rate_hz: 1
            fields: { device_id: "test_device" }
        - stop: gps_tracker

    - name: test_failover_switchover
      description: "Launch primary + standby, kill primary, verify standby takes over"
      steps:
        - launch: { process: gps_tracker, args: "--role PRIMARY" }
        - launch: { process: gps_tracker, args: "--role STANDBY" }
        - wait: 5s
        - verify: { topic: HeartbeatTopic, field: role, value: PRIMARY }
        - kill: { process: gps_tracker, role: PRIMARY }
        - wait: 5s
        - verify: { topic: HeartbeatTopic, field: role, value: PRIMARY, from: standby }
      auto_generated_by: failover.hot_standby

# ============================================================================
# DECISIONS — Traceability log of all planning choices
# ============================================================================
#
# Every decision made during Phase 3 is recorded here with rationale.
# When the user re-enters planning for this process, prior decisions are
# loaded and shown as defaults.
# ============================================================================

decisions:
  - id: plan.transports
    selected: [SHMEM, UDP]
    rationale: "Default — co-located + optional remote"
    timestamp: "2026-03-17T14:30:00Z"

  - id: plan.system_pattern_optin.failover
    selected: "primary"
    rationale: "User opted in as primary node for failover"
    timestamp: "2026-03-17T14:30:05Z"

  - id: plan.system_pattern_optin.health_monitoring
    selected: "publisher"
    rationale: "User opted in to publish health data from this process"
    timestamp: "2026-03-17T14:30:06Z"

  - id: plan.type.CommandTopic
    selected: "gps_types::Command (new)"
    rationale: "No existing Command type — defined new with device_id, action, value"
    timestamp: "2026-03-17T14:30:10Z"

  - id: plan.type.PositionTopic
    selected: "gps_types::Position (new)"
    rationale: "No existing Position type — defined new with lat, lon, alt, timestamp"
    timestamp: "2026-03-17T14:30:12Z"

  - id: plan.pattern.CommandTopic
    selected: "command.1"
    rationale: "Auto-resolved: type name contains 'Command' → Command pattern, single-source"
    timestamp: "2026-03-17T14:30:15Z"

  - id: plan.pattern.PositionTopic
    selected: "status.1"
    rationale: "User confirmed: periodic position data at 2Hz → Standard Status"
    timestamp: "2026-03-17T14:30:18Z"

  - id: plan.tests
    selected: "accepted"
    rationale: "User accepted all auto-proposed tests without modification"
    timestamp: "2026-03-17T14:30:25Z"
