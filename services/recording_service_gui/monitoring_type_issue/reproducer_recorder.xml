<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Recording Service config for the monitoring type issue reproducer.
  Starts a recorder on DOMAIN_ID with admin/monitoring on ADMIN_DOMAIN_ID.

  Usage:
    rtirecordingservice -cfgFile reproducer_recorder.xml \
      -cfgName reproducer -DDOMAIN_ID=0 -DADMIN_DOMAIN_ID=0
-->
<dds>
  <configuration_variables>
    <value>
      <element>
        <name>DOMAIN_ID</name>
        <value>0</value>
      </element>
      <element>
        <name>ADMIN_DOMAIN_ID</name>
        <value>0</value>
      </element>
    </value>
  </configuration_variables>

  <recording_service name="reproducer">
    <administration>
      <domain_id>$(ADMIN_DOMAIN_ID)</domain_id>
    </administration>

    <monitoring>
      <domain_id>$(ADMIN_DOMAIN_ID)</domain_id>
      <status_publication_period>
        <sec>1</sec>
        <nanosec>0</nanosec>
      </status_publication_period>
      <statistics_sampling_period>
        <sec>1</sec>
        <nanosec>0</nanosec>
      </statistics_sampling_period>
    </monitoring>

    <storage>
      <sqlite>
        <storage_format>XCDR_AUTO</storage_format>
        <fileset>
          <workspace_dir>/tmp/reproducer_recording</workspace_dir>
          <execution_dir_expression>run</execution_dir_expression>
          <filename_expression>data.dat</filename_expression>
        </fileset>
      </sqlite>
    </storage>

    <domain_participant name="RecordingParticipant">
      <domain_id>$(DOMAIN_ID)</domain_id>
    </domain_participant>

    <session name="DefaultSession">
      <subscriber_qos>
        <subscriber_name>
          <name>subscriber</name>
        </subscriber_name>
      </subscriber_qos>
    </session>
  </recording_service>
</dds>
