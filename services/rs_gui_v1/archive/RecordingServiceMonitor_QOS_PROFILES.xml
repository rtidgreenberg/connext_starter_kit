<?xml version="1.0"?>
<!--
  QoS Profiles for Recording Service Monitoring Subscription

  These profiles define QoS for the three monitoring DataReaders used by
  the GUI to subscribe to Recording Service monitoring topics:
    - rti/service/monitoring/config   (one-time discovery)
    - rti/service/monitoring/event    (state changes)
    - rti/service/monitoring/periodic (statistics, ~1s)

  Based on the C++ reference example:
  https://github.com/rticommunity/rticonnextdds-examples/tree/master/examples/routing_service/monitoring/c%2B%2B11
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.3.0/rti_dds_qos_profiles.xsd">

    <qos_library name="RecordingServiceMonitorProfiles">

        <!--
          Config profile: KeepLastReliable + TRANSIENT_LOCAL
          Config samples are published once when the service starts.
          Late-joiner must receive them to populate the config lookup table.
        -->
        <qos_profile name="config_Profile"
                     base_name="BuiltinQosLib::Generic.KeepLastReliable">
            <datareader_qos>
                <durability>
                    <kind>TRANSIENT_LOCAL_DURABILITY_QOS</kind>
                </durability>
                <reader_resource_limits>
                    <dynamically_allocate_fragmented_samples>true</dynamically_allocate_fragmented_samples>
                </reader_resource_limits>
                <property>
                    <value>
                        <element>
                            <name>dds.data_reader.history.memory_manager.fast_pool.pool_buffer_max_size</name>
                            <value>4096</value>
                        </element>
                    </value>
                </property>
            </datareader_qos>
        </qos_profile>

        <!--
          Event profile: StrictReliable + TRANSIENT_LOCAL
          State-change events must not be lost; late-joiner gets last state.
        -->
        <qos_profile name="event_Profile"
                     base_name="BuiltinQosLib::Generic.StrictReliable">
            <datareader_qos>
                <durability>
                    <kind>TRANSIENT_LOCAL_DURABILITY_QOS</kind>
                </durability>
                <reader_resource_limits>
                    <dynamically_allocate_fragmented_samples>true</dynamically_allocate_fragmented_samples>
                </reader_resource_limits>
                <property>
                    <value>
                        <element>
                            <name>dds.data_reader.history.memory_manager.fast_pool.pool_buffer_max_size</name>
                            <value>4096</value>
                        </element>
                    </value>
                </property>
            </datareader_qos>
        </qos_profile>

        <!--
          Periodic profile: BestEffort (default durability)
          Periodic stats are high-frequency and loss-tolerant.
        -->
        <qos_profile name="periodic_Profile"
                     base_name="BuiltinQosLib::Generic.BestEffort">
            <datareader_qos>
                <reader_resource_limits>
                    <dynamically_allocate_fragmented_samples>true</dynamically_allocate_fragmented_samples>
                </reader_resource_limits>
                <property>
                    <value>
                        <element>
                            <name>dds.data_reader.history.memory_manager.fast_pool.pool_buffer_max_size</name>
                            <value>4096</value>
                        </element>
                    </value>
                </property>
            </datareader_qos>
        </qos_profile>

    </qos_library>
</dds>
