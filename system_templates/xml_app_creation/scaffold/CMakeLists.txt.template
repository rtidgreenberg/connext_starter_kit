cmake_minimum_required(VERSION 3.12)

project({{PROCESS_NAME_PASCAL}}XmlApp VERSION 1.0.0 LANGUAGES CXX)

# ============================================================================
# GENERATED BY /rti_dev — DDS Process Builder
# Template: system_templates/xml_app_creation/scaffold/CMakeLists.txt.template
#
# XML App Creation — entities are defined in XML, minimal C++ code.
# Application uses create_participant_from_config() to instantiate DDS
# entities from DomainLibrary.xml and ParticipantLibrary.xml.
#
